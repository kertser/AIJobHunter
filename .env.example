# AI Job Hunter configuration
# Copy this file to .env and fill in your values.

# --- LLM Provider ---
JOBHUNTER_OPENAI_API_KEY=sk-...
# JOBHUNTER_LLM_PROVIDER=openai          # "openai" or "local"
# JOBHUNTER_LOCAL_LLM_URL=http://localhost:8080/v1
# JOBHUNTER_LOCAL_LLM_MODEL=             # model name (blank = auto-detect)

# --- Global LLM Inference Defaults ---
# JOBHUNTER_LLM_TEMPERATURE=0.2          # default temperature for all tasks
# JOBHUNTER_LLM_MAX_TOKENS=0             # 0 = provider default (no limit)

# --- Per-task overrides are configured in AppSettings.llm_task_overrides ---
# Task presets (applied automatically):
#   scoring:           temperature=0.2
#   description_clean: temperature=0.1, max_tokens=2000
#   profile_gen:       temperature=0.3
#   market_extract:    temperature=0.0
#   title_normalize:   temperature=0.0
#   form_fill:         temperature=0.1, max_tokens=1000
#   resume_review:     temperature=0.4, max_tokens=2000

# --- General ---
# JOBHUNTER_DATA_DIR=data

# --- Local LLM sidecar server parameters ---
# See config/llm_server.json for model path, context size, threads, etc.

