# ─── Local LLM sidecar — llama-cpp-python with OpenAI-compatible API ───
#
# Serves a GGUF model at http://llm:8080/v1 with the same API shape as
# OpenAI (chat/completions, embeddings).
#
# Build:
#   docker compose build llm
#
# Run standalone:
#   docker run --rm -v ./models:/models -p 8080:8080 ai-job-hunter-llm
#
# Pre-download a model into ./models/ first — see scripts/download_model.*

FROM python:3.12-slim

# Build dependencies for llama-cpp-python (if no pre-built wheel is found)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential cmake curl && \
    rm -rf /var/lib/apt/lists/*

# Install llama-cpp-python with its built-in OpenAI server
RUN pip install --no-cache-dir \
    "llama-cpp-python[server]>=0.3" \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu

WORKDIR /app

# Models are bind-mounted at runtime
VOLUME ["/models"]

# Default config path — override by bind-mounting your own file
COPY config/llm_server.json /app/config/llm_server.json
ENV LLM_CONFIG=/app/config/llm_server.json

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -sf http://localhost:8080/v1/models || exit 1

# Use the built-in OpenAI-compatible server with a config file
ENTRYPOINT ["sh", "-c", \
    "python -m llama_cpp.server --config_file $LLM_CONFIG"]

